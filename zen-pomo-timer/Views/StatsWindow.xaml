<Window x:Class="zen_pomo_timer.Views.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Statistics" Height="600" Width="850"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Icon="/Assets/Icons/stats.ico"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Border Background="{DynamicResource MaterialDesignPaper}"
        CornerRadius="20"
        ClipToBounds="True"
        BorderThickness="1"
        BorderBrush="{DynamicResource MaterialDesignDivider}"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="STATISTICS" FontSize="20" FontWeight="Bold" 
                   Foreground="{DynamicResource ForeColor}" Margin="0,0,0,15"/>
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnMinimize"
                            Width="34" Height="34" Padding="4"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Minimize"
                            Foreground="Gray" Click="btnMinimize_Click">
                    <materialDesign:PackIcon Kind="WindowMinimize" Width="18" Height="18"/>
                </Button>
                <Button x:Name="btnMaximize"
        Width="34" Height="34" Padding="4"
        Style="{StaticResource MaterialDesignIconButton}"
        ToolTip="Maximize"
        Foreground="Gray" Click="btnMaximize_Click">
                    <materialDesign:PackIcon Kind="WindowMaximize" Width="18" Height="18"/>
                </Button>
                <Button x:Name="btnClose"
                            Width="34" Height="34" Padding="4"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Close"
                            Foreground="PaleVioletRed" Click="btnClose_Click">
                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                </Button>
            </StackPanel>
            
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

                <TabItem Header="Today">
                    <Grid Margin="0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="lblTodayTotal" Text="Total: 0.0 hours" FontSize="16" Margin="0,5" Foreground="{DynamicResource ForeColor}"/>
                        <ScottPlot:WpfPlot x:Name="chartToday" Grid.Row="1"/>
                    </Grid>

                </TabItem>

                <TabItem Header="This Week">
                    <Grid Margin="0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="txtCurrentStreak" Text="Current Streak: 0 days" FontSize="16" Margin="0,5" Foreground="{DynamicResource ForeColor}"/>
                        <ScottPlot:WpfPlot x:Name="chartWeek" Grid.Row="1"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Annual Activity">
                    <Grid Margin="0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <UniformGrid Columns="3" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Total Sessions" Opacity="0.6" Foreground="{DynamicResource ForeColor}"/>
                                <TextBlock x:Name="txtAllTimeSessions" Text="0" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ForeColor}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Total Hours" Opacity="0.6" Foreground="{DynamicResource ForeColor}"/>
                                <TextBlock x:Name="txtAllTimeHours" Text="0" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ForeColor}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Best Streak" Opacity="0.6" Foreground="{DynamicResource ForeColor}"/>
                                <TextBlock x:Name="txtBestStreak" Text="0 days" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ForeColor}"/>
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Grid.Row="1" Text="Activity Heat Map" Margin="0,10,0,5" FontWeight="SemiBold" Foreground="{DynamicResource ForeColor}"/>
                        <ScottPlot:WpfPlot x:Name="chartHeatMap" Grid.Row="2"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>