<Window x:Class="zen_pomo_timer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:zen_pomo_timer"
        mc:Ignorable="d"
        Title="Settings" 
        Height="650" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        BorderBrush="{DynamicResource BackgroundColor}"
        Background="{DynamicResource BackgroundColor}"
        Foreground="{DynamicResource ForeColor}"
        Icon="/Assets/Icons/settings.ico"
        >

    <Window.Resources>

        <SolidColorBrush x:Key="PrimaryColor" Color="Purple"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="BorderColorPanel" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="BackgroundColorPanel" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ForeColor" Color="Black"/>

        <!-- Style for TabItems -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border"
                            Background="{DynamicResource BackgroundColorPanel}"
                            BorderBrush="{DynamicResource BorderColorPanel}"
                            BorderThickness="1"
                            Margin="0">
                            <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="15,8"
                                          TextElement.Foreground="{DynamicResource ForeColor}"/>
                        </Border>
                        <ControlTemplate.Triggers>

                            <!-- Selected -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border"
                                Property="Background"
                                Value="{DynamicResource PrimaryColor}"/>
                            </Trigger>

                            <!-- Hover ONLY when NOT selected -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border"
                                Property="Background"
                                Value="{DynamicResource BorderColorPanel}"/>
                                <!-- slightly different hover color -->
                            </MultiTrigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundColorPanel}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForeColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColorPanel}"/>
            <Setter Property="Padding" Value="5"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Padding" Value="5"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryColor}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <TabControl Background="{DynamicResource BackgroundColorPanel}"
                    BorderBrush="{DynamicResource BorderColorPanel}"
                    Margin="10"
                    Grid.Row="0">

            <!-- General Tab -->
            <TabItem Header="General" 
                     Background="Transparent"
                     Foreground="{DynamicResource ForeColor}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,0" Height="475">
                    <StackPanel Margin="10">

                        <GroupBox Header="Timer Duration" 
                                  Margin="0,0,0,0"
                                  Foreground="{DynamicResource ForeColor}"
                                  BorderBrush="{DynamicResource BorderColorPanel}">
                            <StackPanel Margin="10,10,10,10">
                                <Label Content="Pomodoro (minutes):" Foreground="{DynamicResource ForeColor}"/>
                                <TextBox x:Name="txtSessionTime" Margin="0,0,0,10"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"
                                         DataObject.Pasting="TextBox_Pasting" TextChanged="txtSessionTime_TextChanged"/>

                                <Label Content="Short Break (minutes):" Foreground="{DynamicResource ForeColor}"/>
                                <TextBox x:Name="txtShortBreak" Margin="0,0,0,10"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"
                                         DataObject.Pasting="TextBox_Pasting" TextChanged="txtShortBreak_TextChanged"/>

                                <Label Content="Long Break (minutes):" Foreground="{DynamicResource ForeColor}"/>
                                <TextBox x:Name="txtLongBreak" Margin="0,0,0,10"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"
                                         DataObject.Pasting="TextBox_Pasting" TextChanged="txtLongBreak_TextChanged"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Pomodoro Count" 
                                  Margin="0,0,0,10"
                                  Foreground="{DynamicResource ForeColor}"
                                  BorderBrush="{DynamicResource BorderColorPanel}">
                            <StackPanel Margin="10">
                                <Label Content="Pomodoros until long break:" Foreground="{DynamicResource ForeColor}"/>
                                <TextBox x:Name="txtPomodoroBeforeLongBreak"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"
                                         DataObject.Pasting="TextBox_Pasting" 
                                         Foreground="{DynamicResource ForeColor}"
                                         TextChanged="txtPomodoroBeforeLongBreak_TextChanged"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Behavior" 
                                  Margin="0,0,0,10"
                                  Foreground="{DynamicResource ForeColor}"
                                  BorderBrush="{DynamicResource BorderColorPanel}">
                            <StackPanel Margin="10">
                                <CheckBox x:Name="chkAutoStartBreaks" Content="Auto-start breaks" Margin="0,0,0,5" Foreground="{DynamicResource ForeColor}"/>
                                <CheckBox x:Name="chkAutoStartPomodoros" Content="Auto-start pomodoros" Foreground="{DynamicResource ForeColor}"/>
                            </StackPanel>

                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Appearance Tab -->
            <TabItem Header="Appearance" 
                     Background="Transparent"
                     Foreground="{DynamicResource ForeColor}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <GroupBox Header="Colors" 
                                  Margin="0,0,0,10"
                                  Foreground="{DynamicResource ForeColor}"
                                  BorderBrush="{DynamicResource BorderColorPanel}">
                            <StackPanel Margin="10">
                                <Label Content="Primary Color:" Foreground="{DynamicResource ForeColor}"/>
                                <ComboBox x:Name="cmbPrimaryColor" Margin="0,0,0,10" SelectionChanged="cmbPrimaryColor_SelectionChanged" Foreground="Black">
                                    <ComboBoxItem Content="Purple" IsSelected="True" Foreground="Black"/>
                                    <ComboBoxItem Content="Blue" Foreground="Black"/>
                                    <ComboBoxItem Content="Green" Foreground="Black"/>
                                    <ComboBoxItem Content="Red" Foreground="Black"/>
                                    <ComboBoxItem Content="Orange" Foreground="Black"/>
                                </ComboBox>

                                <Label Content="Background Color:" Foreground="{DynamicResource ForeColor}"/>
                                <ComboBox x:Name="cmbBackgroundColor" Foreground="Black" SelectionChanged="cmbBackgroundColor_SelectionChanged">
                                    <ComboBoxItem Content="Dark" IsSelected="True" Foreground="Black"/>
                                    <ComboBoxItem Content="Light" Foreground="Black"/>
                                    <ComboBoxItem Content="System" Foreground="Black"/>
                                </ComboBox>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Sound Tab -->
            <TabItem Header="Sound" 
                     Background="Transparent"
                     Foreground="{DynamicResource ForeColor}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <GroupBox Header="Notifications" 
                                  Margin="0,0,0,10"
                                  Foreground="{DynamicResource ForeColor}"
                                  BorderBrush="{DynamicResource BorderColorPanel}">
                            <StackPanel Margin="10">
                                <Label Content="Notification Tone" Foreground="{DynamicResource ForeColor}"></Label>
                                <ComboBox x:Name="cmbNotificationSound" Margin="0,0,0, 10" Foreground="Black" DropDownClosed="DropNotificationSound_Closed" SelectionChanged="cmbNotificationSound_SelectionChanged">
                                    <ComboBoxItem Content="Default" IsSelected="True" Foreground="Black"></ComboBoxItem>
                                    <ComboBoxItem Content="Calm" Foreground="Black"></ComboBoxItem>
                                    <ComboBoxItem Content="Chord" Foreground="Black"></ComboBoxItem>
                                    <ComboBoxItem Content="Chord2" Foreground="Black"></ComboBoxItem>
                                    <ComboBoxItem Content="Cloud" Foreground="Black"></ComboBoxItem>
                                    <ComboBoxItem Content="Glisten" Foreground="Black"></ComboBoxItem>
                                    <ComboBoxItem Content="Jinja" Foreground="Black"></ComboBoxItem>
                                    <ComboBoxItem Content="Jinja2" Foreground="Black"></ComboBoxItem>
                                    <ComboBoxItem Content="Polite" Foreground="Black"></ComboBoxItem>
                                </ComboBox>
                                <CheckBox x:Name="chkEnableSound" 
                                          Content="Enable sound notifications"
                                          IsChecked="True"
                                          Margin="0,0,0,10"
                                          Foreground="{DynamicResource ForeColor}"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- About Tab -->
            <TabItem Header="About" 
                     Background="Transparent"
                     Foreground="{DynamicResource ForeColor}">
                <StackPanel VerticalAlignment="Center" 
                            HorizontalAlignment="Center"
                            Margin="20">
                    <TextBlock Text="Zen Pomo Timer" 
                               FontSize="24" 
                               FontWeight="Bold"
                               Foreground="{DynamicResource ForeColor}"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Version 1.0.0" 
                               FontSize="14"
                               Foreground="#888888"
                               Margin="0,5,0,20"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </TabItem>
        </TabControl>
        <StackPanel Grid.Row="1"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,0,10,10">
            <Button x:Name="btnCancel" Content="Cancel" 
            Width="60" 
            Margin="5,5,5,5"
            Height="30"
            Background="{DynamicResource PrimaryColor}"
            Foreground="White" 
            FontSize="14"
            Cursor="Hand"
            HorizontalAlignment="Left" Click="btnCancel_Click">
            </Button>
            <Button Content="Save"
                    x:Name="btnSave"
                    Margin="5,5,5,5"
                    Height="30"
                    Width="60"
                    Background="{DynamicResource PrimaryColor}"
                    Foreground="White"
                    FontSize="14"
                    Cursor="Hand" HorizontalAlignment="Left" Click="btnSave_Click">
            </Button>
        </StackPanel>
    </Grid>
</Window>